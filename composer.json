{
    "name": "bit-mx/statamic-toc",
    "description": "Reusable TOC extraction and anchor injection for Statamic Bard and Markdown fields.",
    "type": "statamic-addon",
    "license": "MIT",
    "authors": [
        {
            "name": "Jorge Enríquez",
            "email": "jenriquez@bit.lat"
        }
    ],
    "require": {
        "php": "^8.4",
        "illuminate/support": "^12.0 | ^13.0",
        "statamic/cms": "^6.0"
    },
    "require-dev": {
        "orchestra/testbench": "^v11.1.0",
        "pestphp/pest": "^3.0",
        "phpunit/phpunit": "^11.0",
        "laravel/pint": "^1.27",
        "larastan/larastan": "^3.9",
        "tomasvotruba/type-coverage": "^2.1",
        "phpstan/extension-installer": "^1.4"
    },
    "autoload": {
        "psr-4": {
            "BitMx\\StatamicToc\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "BitMx\\StatamicToc\\Tests\\": "tests/"
        }
    },
    "extra": {
        "statamic": {
            "name": "Statamic TOC",
            "description": "Reusable TOC extraction and anchor injection for Bard and Markdown content."
        },
        "laravel": {
            "providers": [
                "BitMx\\StatamicToc\\StatamicTocServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": false,
            "pixelfear/composer-dist-plugin": false,
            "phpstan/extension-installer": true
        }
    }
}
